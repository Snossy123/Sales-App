# Production: real Laravel API on Hostinger (Vercel SPA)
VITE_DEMO_MODE=false
VITE_API_URL=https://gps.tiger-labtop.com/public/api/v1
VITE_STORAGE_USE_PUBLIC_PREFIX=true

# Guided Tour: localStorage only by default (no API calls, no 404).
